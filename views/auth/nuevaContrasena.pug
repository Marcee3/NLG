doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        title Novias Los Gatitos | #{titulo}
        link(rel="stylesheet", href="/css/style.css")
    body 
        header 
            .logo 
                img(src="/img/logo.png", alt="Novias Los Gatitos" class="img-logo" width="70")
                .txtTitle   
                    h2 Novias Los Gatitos
            .navBar
                a(href="/") Regresar
        main 
            .content 
                form(action=`/recuperar/${token}`, method="post" id="formLogin") 
                    input(type="hidden" name="token" value=token)               
                    div 
                        input(type="password" name="newContrasena" placeholder="Nueva contraseña" required)
                        input(type="password" name="confirmarContrasena" placeholder="Confirmar contraseña" required)

                    input(type="submit", value="Cambiar contraseña")

                    p(id="mensajeError")
    
